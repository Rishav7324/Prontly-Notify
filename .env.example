# Firebase Client
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your-project
NEXT_PUBLIC_FIREBASE_APP_ID=1:123:web:abc

# Cloudflare D1
CF_ACCOUNT_ID=
CF_D1_DATABASE_ID=
CF_D1_API_TOKEN=

# App Config
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Firebase Admin (optional — falls back to REST API if absent)
FIREBASE_SERVICE_ACCOUNT_JSON=

# Brevo (transactional email — required for auth emails)
BREVO_API_KEY=
EMAIL_FROM_TRANSACTIONAL=hello@prontly.in
BREVO_DAILY_SEND_LIMIT=300

# SMTP (used as fallback if Brevo is not configured)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
