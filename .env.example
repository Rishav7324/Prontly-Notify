# ── Firebase Client ─────────────────────────────────────────────────────────
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your-project
NEXT_PUBLIC_FIREBASE_APP_ID=1:123:web:abc

# ── Firebase Admin Service Account ──────────────────────────────────────────
# Raw JSON from Firebase Console → Project Settings → Service Accounts.
# Required for OAuth2 token generation (server-side sendOobCode with
# returnOobLink). Without this, auth emails will fail with
# INSUFFICIENT_PERMISSION on the Firebase Identity Toolkit.
FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"your-project",...}

# ── Brevo (Sendinblue) Transactional Email ─────────────────────────────────
BREVO_API_KEY=
EMAIL_FROM_TRANSACTIONAL=noreply@yourdomain.com
BREVO_DAILY_SEND_LIMIT=300

# ── Cloudflare D1 ───────────────────────────────────────────────────────────
CF_ACCOUNT_ID=
CF_D1_DATABASE_ID=
CF_D1_API_TOKEN=

# ── App ─────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
