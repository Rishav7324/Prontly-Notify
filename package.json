{
  "name": "prontly-notify",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev -H 127.0.0.1",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "routes": "tsx scripts/discover-routes.ts",
    "load-test": "tsx scripts/load-test.ts",
    "db:migrate:local": "wrangler d1 execute prontly-notify-prod --local --file=./db/migrations/0001_init.sql",
    "db:migrate:staging": "wrangler d1 execute prontly-notify-staging --remote --file=./db/migrations/0001_init.sql",
    "db:migrate:prod": "wrangler d1 execute prontly-notify-prod --remote --file=./db/migrations/0001_init.sql",
    "db:studio": "drizzle-kit studio",
    "db:backup": "wrangler d1 export prontly-notify-prod --remote --output=./backups/backup-$(date +%Y%m%d).sql",
    "r2:list-public": "wrangler r2 object list prontly-notify-public",
    "r2:list-private": "wrangler r2 object list prontly-notify-private"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1085.0",
    "@aws-sdk/s3-request-presigner": "^3.1085.0",
    "@getbrevo/brevo": "^6.0.2",
    "@react-email/components": "^1.0.12",
    "@tailwindcss/forms": "^0.5.11",
    "@tailwindcss/typography": "^0.5.20",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.4.0",
    "drizzle-orm": "^0.45.2",
    "firebase": "^12.15.0",
    "firebase-admin": "^14.0.0",
    "lucide-react": "^1.21.0",
    "next": "16.2.9",
    "nodemailer": "^9.0.3",
    "razorpay": "^2.9.6",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-email": "^6.6.9",
    "recharts": "^3.9.0",
    "tailwind-merge": "^3.6.0",
    "zod": "^4.4.3",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^20",
    "@types/nodemailer": "^8.0.1",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "drizzle-kit": "^0.31.10",
    "eslint": "^9",
    "eslint-config-next": "16.2.9",
    "jsdom": "^29.1.1",
    "tailwindcss": "^4",
    "typescript": "^5",
    "vitest": "^4.1.9"
  }
}
